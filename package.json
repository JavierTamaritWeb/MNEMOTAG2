{
  "name": "mnemotag",
  "private": true,
  "version": "3.7.2",
  "description": "Editor profesional de metadatos e imágenes — 100% cliente, sin backend",
  "scripts": {
    "build": "gulp build",
    "watch": "gulp watch",
    "dev": "gulp dev",
    "serve": "gulp serve",
    "scss": "gulp scss",
    "js": "gulp js",
    "test": "node tests/run-in-node.js && node tests/binary-validation.js",
    "prepare": "git config core.hooksPath .githooks",
    "test:e2e": "playwright test",
    "test:e2e:dist": "playwright test -c playwright.dist.config.js",
    "lint:js": "eslint --no-config-lookup -c eslint.config.js js/",
    "lint:css": "stylelint \"src/scss/**/*.scss\""
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@fortawesome/fontawesome-free": "^6.4.0",
    "@playwright/test": "^1.61.1",
    "browser-sync": "^3.0.4",
    "eslint": "^9.39.5",
    "fontawesome-subset": "^4.6.0",
    "gulp": "^5.0.0",
    "gulp-clean-css": "^4.3.0",
    "gulp-concat": "^2.6.1",
    "gulp-rename": "^2.0.0",
    "gulp-sass": "^6.0.0",
    "gulp-sourcemaps": "^3.0.0",
    "gulp-terser": "^2.1.0",
    "html-minifier-terser": "^7.2.0",
    "postcss-scss": "^4.0.9",
    "purgecss": "^8.0.0",
    "sass": "^1.77.0",
    "sharp": "^0.34.5",
    "stylelint": "^16.26.1",
    "tailwindcss": "^2.2.19"
  },
  "author": "Javier Tamarit",
  "license": "MIT"
}
